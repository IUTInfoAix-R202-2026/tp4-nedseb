<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="fr.univ_amu.iut.exercice2.CompteurController"
      spacing="16"
      alignment="CENTER"
      style="-fx-padding: 24; -fx-min-width: 320;">

  <Label fx:id="labelCompteur" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" />

  <HBox spacing="10" alignment="CENTER">
    <Button text="−" onAction="#surDecrementer" style="-fx-font-size: 16px; -fx-min-width: 44px;" />
    <Button text="Réinitialiser" onAction="#surReinitialiser" style="-fx-min-width: 120px;" />
    <Button text="+" onAction="#surIncrementer" style="-fx-font-size: 16px; -fx-min-width: 44px;" />
  </HBox>
</VBox>
