<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>

<!--
  Vue de l'exercice 1 (MVVM minimal).

  fx:controller désigne le contrôleur de vue. Comme MessageApp installe un
  controllerFactory, c'est ce factory qui fournit l'instance du contrôleur
  (avec son ViewModel déjà injecté).
-->
<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="fr.univ_amu.iut.exercice1.MessageController"
      spacing="12"
      style="-fx-padding: 20; -fx-min-width: 360;">

  <Label text="Saisissez un message :" />
  <TextField fx:id="champTexte" promptText="Tapez ici..." />

  <Label fx:id="labelApercu"
         maxWidth="Infinity"
         style="-fx-font-weight: bold; -fx-font-size: 14px; -fx-background-color: #eaf3fb; -fx-border-color: #4a90d9; -fx-background-radius: 4; -fx-border-radius: 4; -fx-padding: 9 12;" />
</VBox>
